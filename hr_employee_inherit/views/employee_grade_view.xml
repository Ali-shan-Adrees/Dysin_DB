<?xml version="1.0" encoding="utf-8" ?>
<odoo>


    <!--    Iherit Employee Form data -->
    <record id="hr_employe_form_view_inherit" model="ir.ui.view">
        <field name="name">hr.employee.view.form.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form//sheet//group//group[1]//field[@name='work_email']" position="after">
                <field name="contract_id"/>
            </xpath>
            <!--			Employee Grade-->
            <xpath expr="//form//sheet//div[3]/h2" position="after">
                <h3>
                    <field name="job_levels_id"  string="Job Levels" options="{'no_create': True, 'no_edit': True, 'no_open': True}"
                           placeholder="Grade" required="1"/>
                </h3>
            </xpath>
            <xpath expr="//form//sheet//notebook//page[2]//group//group[1]//field[@name='private_email']"
                   position="before">
                <!--                <field name="home_address_id"/>-->
                <!--                <field name="address_home_id"/>-->
                <field name="employee_address"/>
                <field name="private_phone_no"/>
                <field name="private_email_no"/>
                <field name="employee_bank_name"/>
                <field name="employee_account_title"/>
                <field name="employee_account_number"/>
                <field name="km_home_work"/>
                <field name="city"/>
            </xpath>
            <!--            Below path adding new field for father name-->
            <xpath expr="//form//sheet//notebook//page[@name='personal_information']//group//group[2]//field[@name='marital']"
                   position="before">
                <field name="employee_father"/>
            </xpath>
			<xpath expr="//form//sheet//notebook//page[@name='personal_information']//group//group[3]//field[@name='certificate']"
                   position="after">
                <field name="education_certificate"/>
            </xpath>
            <xpath  expr="//form//sheet//notebook//page[@name='personal_information']//group//group[3]//field[@name='certificate']"
                   position="attributes">
                <attribute name="invisible">1</attribute>

            </xpath>

            <xpath expr="//page[@name='personal_information']//field[@name='identification_id']" position="after">
                <field name="employee_cnic_issue_date"/>
                <field name="employee_NTN_no" invisible="1"/>
            </xpath>
            <xpath expr="//form//sheet//notebook//page[@name='personal_information']//group//group[3]//field[@name='study_school']"
                   position="after">
                <field name="education_detail_report">
                    <tree editable="bottom">
                        <field name="level"/>
                        <field name="institute"/>
                        <field name="marks"/>
                    </tree>
                </field>
            </xpath>
            <xpath expr="//form//sheet//notebook//page[@name='personal_information']//group//group[2]/field[@name='emergency_phone']"
                   position="after">
                <field name="blood_group"/>
            </xpath>
            <xpath expr="//form//sheet//notebook//page[@name='personal_information']//group" position="after">
                <group>
                    <!--					<group string="Dependants">-->
                    <!--						<field name="children"/>-->
                    <!--					</group>-->
                </group>
                <group string="Dependants Details" name="children_detail_group">
                    <group>
                        <field name="child_name_1" attrs="{'invisible':[('children','=',0)]}"/>
                        <field name="child_name_2" attrs="{'invisible':[('children','&lt;',2)]}"/>
                        <field name="child_name_3" attrs="{'invisible':[('children','&lt;',3)]}"/>
                        <field name="child_name_4" attrs="{'invisible':[('children','&lt;',4)]}"/>
                        <field name="child_name_5" attrs="{'invisible':[('children','&lt;',5)]}"/>
                        <field name="child_name_6" attrs="{'invisible':[('children','&lt;',6)]}"/>
                        <field name="child_name_7" attrs="{'invisible':[('children','&lt;',7)]}"/>
                        <field name="child_name_8" attrs="{'invisible':[('children','&lt;',8)]}"/>
                        <field name="child_name_9" attrs="{'invisible':[('children','&lt;',9)]}"/>
                        <field name="child_name_10" attrs="{'invisible':[('children','&lt;',10)]}"/>
                        <field name="child_name_11" attrs="{'invisible':[('children','&lt;',11)]}"/>
                        <field name="child_name_12" attrs="{'invisible':[('children','&lt;',12)]}"/>
                    </group>
                    <group>
                        <group>
                            <field name="child_REL_1" attrs="{'invisible':[('children','=',0)]}"/>
                            <field name="child_REL_2" attrs="{'invisible':[('children','&lt;',2)]}"/>
                            <field name="child_REL_3" attrs="{'invisible':[('children','&lt;',3)]}"/>
                            <field name="child_REL_4" attrs="{'invisible':[('children','&lt;',4)]}"/>
                            <field name="child_REL_5" attrs="{'invisible':[('children','&lt;',5)]}"/>
                            <field name="child_REL_6" attrs="{'invisible':[('children','&lt;',6)]}"/>
                            <field name="child_REL_7" attrs="{'invisible':[('children','&lt;',7)]}"/>
                            <field name="child_REL_8" attrs="{'invisible':[('children','&lt;',8)]}"/>
                            <field name="child_REL_9" attrs="{'invisible':[('children','&lt;',9)]}"/>
                            <field name="child_REL_10" attrs="{'invisible':[('children','&lt;',10)]}"/>
                            <field name="child_REL_11" attrs="{'invisible':[('children','&lt;',11)]}"/>
                            <field name="child_REL_12" attrs="{'invisible':[('children','&lt;',12)]}"/>
                        </group>
                        <group>
                            <field name="child_DOB_1" attrs="{'invisible':[('children','=',0)]}"/>
                            <field name="child_DOB_2" attrs="{'invisible':[('children','&lt;',2)]}"/>
                            <field name="child_DOB_3" attrs="{'invisible':[('children','&lt;',3)]}"/>
                            <field name="child_DOB_4" attrs="{'invisible':[('children','&lt;',4)]}"/>
                            <field name="child_DOB_5" attrs="{'invisible':[('children','&lt;',5)]}"/>
                            <field name="child_DOB_6" attrs="{'invisible':[('children','&lt;',6)]}"/>
                            <field name="child_DOB_7" attrs="{'invisible':[('children','&lt;',7)]}"/>
                            <field name="child_DOB_8" attrs="{'invisible':[('children','&lt;',8)]}"/>
                            <field name="child_DOB_9" attrs="{'invisible':[('children','&lt;',9)]}"/>
                            <field name="child_DOB_10" attrs="{'invisible':[('children','&lt;',10)]}"/>
                            <field name="child_DOB_11" attrs="{'invisible':[('children','&lt;',11)]}"/>
                            <field name="child_DOB_12" attrs="{'invisible':[('children','&lt;',12)]}"/>

                        </group>
                    </group>
                </group>
            </xpath>

            <xpath expr="//form//sheet//notebook//page[@name='hr_settings']" position="after">
                <page name="benefits_employee" string="Benefits">
                    <group>
                        <group string="Insurance Details">
                            <field name="insurance_number"/>
                            <field name="valid_till"/>
                            <field name="insurance_plan"/>
                            <field name="company_currency" invisible="1"/>
                            <field name="probation_check" invisible="1"/>
                            <field name="probation_check_5_months" invisible="1"/>
                            <field name="insurance_amount" class="oe_inline" widget="monetary"
                                   options="{'currency_field': 'company_currency'}"/>
                        </group>
                        <group string="General Benefits">
                            <field name="petrol_liter"/>
                            <field name="mobile_package"/>
                            <field name="system_required"/>
                            <field name="car_allocation" placeholder="1000CC"/>
                        </group>
                        <group string="EOBI Details">
                            <field name="eobi_employee_card_no"/>
                            <field name="eobi_employee_contribution"/>
                            <field name="eobi_employer_contribution"/>
                        </group>
                    </group>
                </page>
                <page string="Accounting Info">
                    <group>
                        <group string="Configure Accounts For">
                            <!--								<field name="advance_against_expense_acc_id"  options='{"no_open": True, "no_edit": True, "no_create": True}'/>-->
                            <field name="advance_against_salary_acc_id"
                                   options='{"no_open": True, "no_edit": True, "no_create": True}'/>
                            <field name="employee_loan_acc_id"
                                   options='{"no_open": True, "no_edit": True, "no_create": True}'/>
                        </group>
                    </group>
                </page>

                <page string="Loan" invisible="0">
                    <group>
                        <field name="is_loan_applicable"/>
                    </group>
                    <group string="Loan Details" attrs="{'invisible': [('is_loan_applicable','!=',True)]}">
                        <group>
                            <field name="installment_start_date"
                                   attrs="{'required': [('is_loan_applicable','=',True)]}"/>
                            <field name="installment_end_date"/>
                        </group>
                        <group>
                            <field name="loan_amount" attrs="{'required': [('is_loan_applicable','=',True)]}"/>
                            <field name="installments" attrs="{'required': [('is_loan_applicable','=',True)]}"/>
                            <field name="installment_amount"/>
                        </group>
                    </group>
                </page>
            </xpath>
            <!--            adding new field for date of joining-->
            <xpath expr="//form//sheet//group//group[2]//field[@name='coach_id']" position="after">
                <field name="joining_date" force_save="1"/>
                <field name="confirmation_date" force_save="1"/>

            </xpath>
            <xpath expr="//form//sheet//group//group[1]//field[@name='work_email']" position="after">
                <field name="job_status"/>
              <!--   <field name="new_shift_type" options='{"no_open": True, "no_edit": True, "no_create": True}'
                       domain="[('state', '=', 'approved')]"/> -->
                <field name="rest_days" widget="many2many_tags"
                       options='{"no_open": True, "no_edit": True, "no_create": True}'/>
                <field name="date_of_leaving" readonly="1" force_save="1"
                       attrs="{'invisible':[('date_of_leaving','=',False)]}"/>
            </xpath>
            <!--			<xpath expr="//form//sheet//notebook//page[@name='personal_information']//group//group[3]//field[@name='certificate']" position="replace">-->
            <!--				<field name="education_certificate"/>-->
            <!--			</xpath>-->

            <!--            Replace employee Type to employee status in hr.employee model-->
            <!--            <xpath expr="//page[@name='hr_settings']//field[@name='employee_type']" position="after">-->
            <!--                <field name="employee_status"/>-->
            <!--            </xpath>-->
            <xpath expr="//form//sheet//notebook//page[@name='personal_information']//field[@name='private_email']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form//sheet//notebook//page[@name='personal_information']//field[@name='phone']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form//sheet//notebook//page[@name='personal_information']//group//group[1]//field[@name='bank_account_id']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <field name="place_of_birth" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <field name="country_of_birth" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <xpath expr="//form//sheet//notebook//page[@name='personal_information']//field[@name='address_home_id']"
                   position="attributes">
                <attribute name="readonly">1</attribute>
                <attribute name="force_save">1</attribute>
            </xpath>
            <xpath expr="//page[@name='hr_settings']//field[@name='employee_type']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form//sheet//notebook//page[@name='personal_information']//group[2]//field[@name='children']"
                   position="attributes">
                <attribute name="string">No of Dependants</attribute>
            </xpath>
            <xpath expr="//page[@name='personal_information']//field[@name='identification_id']" position="attributes">
                <attribute name="placeholder">e.g 12345-1234567-1</attribute>
                <attribute name="required">1</attribute>
            </xpath>
            <xpath expr="//page[@name='personal_information']//field[@name='gender']" position="attributes">
                <attribute name="required">1</attribute>
            </xpath>
            <xpath expr="//form//sheet//group//group[2]//field[@name='department_id']" position="attributes">
                <attribute name="required">1</attribute>
            </xpath>
            <xpath expr="//form//sheet//group//group[2]//field[@name='job_id']" position="attributes">
                <attribute name="required">1</attribute>
            </xpath>
            <xpath expr="//form//sheet//group//group[2]//field[@name='parent_id']" position="attributes">
                <attribute name="required">1</attribute>
            </xpath>
            <xpath expr="//form//sheet//group//group[1]//field[@name='mobile_phone']" position="attributes">
                <attribute name="required">1</attribute>
            </xpath>
            <xpath expr="//form//sheet//group//group[1]//field[@name='work_phone']" position="attributes">
                <attribute name="required">1</attribute>
            </xpath>
            <xpath expr="//form//sheet//group//group[3]//field[@name='certificate']" position="attributes">
                <attribute name="required">1</attribute>
                <attribute name="string">Degree</attribute>
            </xpath>
            <xpath expr="//form//sheet//group//group[3]//field[@name='study_field']" position="attributes">
                <attribute name="required">1</attribute>
            </xpath>
            <xpath expr="//form//sheet//group//group[3]//field[@name='study_school']" position="attributes">
                <attribute name="required">1</attribute>
                <attribute name="string">Institute</attribute>
            </xpath>
            <xpath expr="//form//sheet//notebook//page[@name='personal_information']//group//group[4]//field[@name='identification_id']" position="attributes">
                <attribute name="string">CNIC No</attribute>
            </xpath>
            <xpath expr="//form//sheet//group//group[2]//field[@name='job_id']" position="attributes">
                <attribute name="string">Designation</attribute>
            </xpath>
        </field>
    </record>
</odoo>