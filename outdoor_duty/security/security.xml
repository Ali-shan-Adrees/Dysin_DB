<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record model="ir.module.category" id="module_category_od">
        <field name="name">Od Management</field>
        <field name="description">Category for Outdoor Duty</field>
        <field name="sequence">45</field>
    </record>
    <record id="group_od_user" model="res.groups">
        <field name="name">User: Own Documents Only</field>
        <field name="category_id" ref="module_category_od"/>
        <field name="comment">the user will have access to his own data in the sales application.</field>
    </record>
    <record id="group_sub_hod" model="res.groups">
        <field name="name">Sub HOD</field>
        <field name="category_id" ref="module_category_od"/>
    </record>


    <record id="group_od_manager" model="res.groups">
        <field name="name">Manager,Assistant Manager</field>
        <field name="category_id" ref="module_category_od"/>
    </record>

    <record id="group_od_regional_admin" model="res.groups">
        <field name="name">Regional Admin</field>
        <field name="category_id" ref="module_category_od"/>
    </record>
    <record id="group_od_management" model="res.groups">
        <field name="name">Management</field>
        <field name="category_id" ref="module_category_od"/>
    </record>
    <record id="group_od_department_coordinator" model="res.groups">
        <field name="name">Department Coordinator</field>
        <field name="category_id" ref="module_category_od"/>
    </record>
    <record id="group_travel_authority_audit" model="res.groups">
        <field name="name">Audit</field>
        <field name="category_id" ref="module_category_od"/>
    </record>
    <record id="group_travel_authority_cfo" model="res.groups">
        <field name="name">CFO</field>
        <field name="category_id" ref="module_category_od"/>
    </record>
    <record id="group_od_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="category_id" ref="module_category_od"/>
        <field name="implied_ids" eval="False"/>
    </record>
    <record id="group_ta_finance" model="res.groups">
        <field name="name">Finance/Cashier</field>
        <field name="category_id" ref="module_category_od"/>
    </record>
    <record id="group_od_administrator" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="module_category_od"/>
    </record>

    <record id="user_od_record_rule" model="ir.rule">
        <field name="name">Only Own Records</field>
        <field name="model_id" ref="outdoor_duty.model_outdoor_duty"/>
        <field name="domain_force">[('user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('outdoor_duty.group_od_user'))]"/>
    </record>
    <record model="ir.rule" id="sub_hod_od_record_rule">
        <field name="name">only own team Records(Sub HOD)</field>
        <field name="model_id" ref="model_outdoor_duty"/>
        <field name="domain_force">['|',('user_id','=',user.id),('coach_id.user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('outdoor_duty.group_sub_hod'))]"/>
    </record>
    <record model="ir.rule" id="manager_od_record_rule">
        <field name="name">only own team Records</field>
        <field name="model_id" ref="model_outdoor_duty"/>
        <field name="domain_force">
            ['|','|',('user_id','=',user.id),('manager_id.user_id','=',user.id),('coach_id.user_id','=',user.id)]
        </field>
        <field name="groups" eval="[(4, ref('outdoor_duty.group_od_manager'))]"/>
    </record>
    <!--    <record id="regional_admin_od_record_rule" model="ir.rule">-->
    <!--        <field name="name">Regional Admin</field>-->
    <!--        <field name="model_id" ref="outdoor_duty.model_outdoor_duty"/>-->
    <!--        <field name="domain_force">['|',('user_id','=',user.id),('employee_id.regional_admin.id','=',user.id)]</field>-->
    <!--        <field name="groups" eval="[(4, ref('outdoor_duty.group_od_regional_admin'))]"/>-->
    <!--    </record>-->

    <record id="admin_od_record_rule" model="ir.rule">
        <field name="name">Admin</field>
        <field ref="outdoor_duty.model_outdoor_duty" name="model_id"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('outdoor_duty.group_od_admin'))]"/>
    </record>

    <record id="audit_od_record_rule" model="ir.rule">
        <field name="name">Audit</field>
        <field name="model_id" ref="outdoor_duty.model_outdoor_duty"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('outdoor_duty.group_travel_authority_audit'))]"/>
    </record>
    <record id="management_od_record_rule" model="ir.rule">
        <field name="name">Management</field>
        <field name="model_id" ref="outdoor_duty.model_outdoor_duty"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('outdoor_duty.group_od_management'))]"/>
    </record>
    <record id="administrator_od_record_rule" model="ir.rule">
        <field name="name">Administrator</field>
        <field name="model_id" ref="outdoor_duty.model_outdoor_duty"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('outdoor_duty.group_od_administrator'))]"/>
    </record>

    <record id="user_travel_authority_record_rule" model="ir.rule">
        <field name="name">Travel Authority Own Records</field>
        <field name="model_id" ref="outdoor_duty.model_travel_authority"/>
        <field name="domain_force">[('user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('outdoor_duty.group_od_user'))]"/>
    </record>
    <record id="hod_travel_authority_record_rule" model="ir.rule">
        <field name="name">Travel Authority Own Team Records</field>
        <field name="model_id" ref="outdoor_duty.model_travel_authority"/>
        <field name="domain_force">
            ['|','|',('user_id','=',user.id),('manager_id.user_id','=',user.id),('coach_id.user_id','=',user.id)]
        </field>
        <field name="groups" eval="[(4, ref('outdoor_duty.group_od_manager'))]"/>
    </record>
    <record id="sub_hod_travel_authority_record_rule" model="ir.rule">
        <field name="name">Travel Authority Sub HOD record</field>
        <field name="model_id" ref="outdoor_duty.model_travel_authority"/>
        <field name="domain_force">['|',('user_id','=',user.id),('coach_id.user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('outdoor_duty.group_sub_hod'))]"/>
    </record>
