<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="attendance_pdf">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="article o_report_layout_standard" t-att-data-oe-model="o and o._name"
                     t-att-data-oe-id="o and o.id">
                    <t t-call="sl_attendance_xlsx_report.attendance_custom_header_footer"/>
                    <div class="page">
                        <table class="table table-sm mt16"
                               style="width:100%;border:1px solid black;border-collapse:collapse;">
                            <thead>
                                <tr>
                                    <th>
                                        <strong>Start Date:</strong>
                                    </th>
                                    <th>
                                        <t t-esc="doc.start_date"/>
                                    </th>
                                    <th>
                                        <strong>End Date:</strong>
                                    </th>
                                    <th colspan="2">
                                        <t t-esc="doc.end_date"/>
                                    </th>
                                </tr>
                                <tr>
                                    <th style="border:1px solid black;">Employee</th>
                                    <th style="border:1px solid black;">Department</th>
                                    <th style="border:1px solid black;">Date</th>
                                    <th style="border:1px solid black;">Check In</th>
                                    <th style="border:1px solid black;">Check Out</th>
                                    <!--                                <th style="border:1px solid black;">Status</th>-->
                                </tr>
                            </thead>
                            <tbody>
                                <t t-if="attendance_data">
                                    <t t-foreach="attendance_data" t-as="line">
                                        <tr>
                                            <td style="border:1px solid black;">
                                                <t t-esc="line['employee']"/>
                                            </td>
                                            <td style="border:1px solid black;">
                                                <t t-esc="line['department']"/>
                                            </td>
                                            <td style="border:1px solid black;">
                                                <t t-if="line['check_in']">
                                                    <t t-esc="line['date'].strftime('%Y-%m-%d')"/>
                                                </t>
                                                <t t-else="">
                                                    <t t-esc="'-'"/>
                                                </t>
                                            </td>
                                            <td style="border:1px solid black;">

                                                <t t-if="line['check_in']">
                                                    <t t-esc="line['check_in'].strftime('%H:%M:%S')"/>
                                                </t>
                                                <t t-else="">
                                                    <t t-esc="'-'"/>
                                                </t>
                                            </td>
                                            <td style="border:1px solid black;">
                                                <t t-if="line['check_out']">
                                                    <t t-if="line['check_out']">
                                                        <t t-esc="line['check_out'].strftime('%H:%M:%S')"/>
                                                    </t>
                                                    <t t-else="">
                                                        <t t-esc="'-'"/>
                                                    </t>
                                                </t>
                                            </td>
                                            <!--                                        <td style="border:1px solid black;"><t t-esc="line['status']"/></td>-->
                                        </tr>
                                    </t>
                                </t>
                                <t t-else="">
                                    <tr>
                                        <td colspan="5" style="text-align:center;border:1px solid black;">
                                            No attendance records found for this period.
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>
            </t>

        </t>
    </template>
</odoo>
