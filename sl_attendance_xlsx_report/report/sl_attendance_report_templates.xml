<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="slt_attendance_report_pdf">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="page">
                    <h2>Attendance Summary</h2>
                    <p>
                        <strong>Period:</strong>
                        <span t-esc="doc.get('start_date')"/> to <span t-esc="doc.get('end_date')"/>
                        &nbsp;&nbsp; <strong>Total days:</strong> <span t-esc="doc.get('days_total')"/>
                        &nbsp;&nbsp; <strong>Weekends:</strong> <span t-esc="doc.get('weekends')"/>
                        &nbsp;&nbsp; <strong>Public Holidays:</strong> <span t-esc="doc.get('public_holidays')"/>
                    </p>

                    <t t-foreach="doc.get('departments')" t-as="dept">
                        <h3 style="margin-top: 18px; background:#f3f3f3; padding:6px;">
                            <span t-esc="dept.get('department_name')"/>
                        </h3>
                        <table class="table table-sm" style="width:100%; border-collapse: collapse;" border="1">
                            <thead>
                                <tr>
                                    <th style="padding:4px">Sr No</th>
                                    <th style="padding:4px">Employee Code</th>
                                    <th style="padding:4px">Name</th>
                                    <th style="padding:4px">Designation</th>
                                    <th style="padding:4px">Total Present Day</th>
                                    <th style="padding:4px">Total Leave</th>
                                    <th style="padding:4px">Total Holidays</th>
                                    <th style="padding:4px">Leave Without Pay</th>
                                    <th style="padding:4px">Total Absent</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-if="dept.get('employees')">
                                    <t t-foreach="dept.get('employees')" t-as="line" t-key="line['employee_id']">
                                        <tr>
                                            <td style="padding:4px; text-align:center;">
                                                <t t-esc="loop.index"/>
                                            </td>
                                            <td style="padding:4px;"><t t-esc="line.get('employee_code') or '-'"/></td>
                                            <td style="padding:4px;"><t t-esc="line.get('name')"/></td>
                                            <td style="padding:4px;"><t t-esc="line.get('designation') or '-'"/></td>
                                            <td style="padding:4px; text-align:center;"><t t-esc="line.get('present')"/></td>
                                            <td style="padding:4px; text-align:center;"><t t-esc="line.get('total_leaves')"/></td>
                                            <td style="padding:4px; text-align:center;"><t t-esc="line.get('total_holidays')"/></td>
                                            <td style="padding:4px; text-align:center;"><t t-esc="line.get('unpaid_leaves')"/></td>
                                            <td style="padding:4px; text-align:center;"><t t-esc="line.get('absent')"/></td>
                                        </tr>
                                    </t>
                                </t>
                                <t t-if="not dept.get('employees')">
                                    <tr><td colspan="9" style="padding:8px">No employees in this department</td></tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                </div>
            </t>
        </t>
    </template>

    <!-- Report action (server) -->
    <report
        id="attendance_report_pdf"
        model="attendance.report.wizard"
        string="Attendance Report"
        report_type="qweb-pdf"
        name="sl_attendance_xlsx_report.slt_attendance_report_pdf"
        file="sl_attendance_xlsx_report.slt_attendance_report_pdf"
        attachment_use="False"
    />
</odoo>
