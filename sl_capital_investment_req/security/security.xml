<odoo>
    <!-- HOD -->
    <record id="group_cir_hod" model="res.groups">
        <field name="name">CIR: HOD</field>
        <field name="category_id" ref="base.module_category_human_resources"/>
    </record>
    <!-- HR -->
    <record id="group_cir_hr" model="res.groups">
        <field name="name">CIR: HR</field>
        <field name="category_id" ref="base.module_category_human_resources"/>
    </record>
    <!-- CFO -->
    <record id="group_cir_cfo" model="res.groups">
        <field name="name">CIR: CFO</field>
        <field name="category_id" ref="base.module_category_human_resources"/>
    </record>
    <record id="sl_cir_rule_user_own" model="ir.rule">
        <field name="name">CIR: Own Records</field>
        <field name="model_id" ref="model_sl_capital_investment"/>
        <field name="domain_force">[('user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- HOD can see all records in their department -->
    <record id="sl_cir_rule_hod_department" model="ir.rule">
        <field name="name">CIR: Department Admin Access</field>
        <field name="model_id" ref="model_sl_capital_investment"/>
        <field name="domain_force">
            [
            '|',
            ('user_id.employee_id.department_id.department_admin_id','=',user.id),
            ('user_id','=',user.id)
            ]
        </field>
        <field name="groups" eval="[(4, ref('sl_capital_investment_req.group_cir_hod'))]"/>
    </record>

    <record id="sl_cir_rule_hr_department" model="ir.rule">
        <field name="name">CIR: HR Department Access</field>
        <field name="model_id" ref="model_sl_capital_investment"/>
        <field name="domain_force">
            [
            '|',
            ('user_id.employee_id.department_id.regional_admin_ids','=',user.id),
            ('user_id','=',user.id)
            ]
        </field>
        <field name="groups" eval="[(4, ref('sl_capital_investment_req.group_cir_hr'))]"/>
    </record>
    <record id="sl_cir_rule_cfo_department" model="ir.rule">
        <field name="name">CIR: CFO Department Access</field>
        <field name="model_id" ref="model_sl_capital_investment"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('sl_capital_investment_req.group_cir_cfo'))]"/>
    </record>
</odoo>
