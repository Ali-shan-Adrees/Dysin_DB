<?xml version="1.0" encoding="utf-8"?>

<odoo>
	<data>
		<record model="ir.ui.view" id="missing_days_tree_view">
			<field name="name">missing.days.report.tree</field>
			<field name="model">missing.days.report</field>
			<field name="arch" type="xml">
				<tree create="0" edit="0" delete="0">
					<field name="employee_id" />
					<field name="date" />
					<field name="day" />
					<field name="day_period"/>
					<field name="hours" />
				</tree>
			</field>
		</record>

		<record model="ir.ui.view" id="missing_days_search_view">
			<field name="name">missing.days.report.search</field>
			<field name="model">missing.days.report</field>
			<field name="type">search</field>
			<field name="arch" type="xml">
				<search>
					<field name="employee_id" />
					<group expand="0" name="group_by" string="Group By">
                        <filter name="group_employee_id" string="Employee" context="{'group_by': 'employee_id'}"/>
                        <filter name="group_day" string="Week Days" context="{'group_by': 'day'}"/>
                    </group>
				</search>
			</field>
		</record>
		
		<record id="missing_days_wizard_view" model="ir.ui.view">
            <field name="name">missing.days.wizard.view</field>
            <field name="model">missing.days.wizard</field>
            <field name="arch" type="xml">
                <form string="Missing Days">
					<group>
						<group>
							<field name="from_date" />
						</group>
						<group>
							<field name="to_date" />
						</group>
					</group>
					<group string="Employees">
						<field name="employee_ids" colspan="2" nolabel="1"/>
					</group>

					<footer>
                        <button string="Open" name="open" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel" />
                    </footer>
				</form>
			</field>
		</record>
		
		<record id="missing_days_wizard_action" model="ir.actions.act_window">
            <field name="name">Missing Attendance</field>
            <field name="res_model">missing.days.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

		<menuitem name="Missing Attendance" id="missing_days_wizard_menu"
			parent="hr_attendance.menu_hr_attendance_root" action="missing_days_wizard_action"
			sequence="50" groups="hr_attendance.group_hr_attendance_user" />
	</data>
</odoo>
