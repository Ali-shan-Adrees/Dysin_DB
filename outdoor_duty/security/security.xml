    <record id="admin_travel_authority_record_rule" model="ir.rule">
        <field name="name">Admin Travel Authority</field>
        <field ref="outdoor_duty.model_travel_authority" name="model_id"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('outdoor_duty.group_od_admin'))]"/>
    </record>
    <record id="audit_travel_authority_rule" model="ir.rule">
        <field name="name">Audit</field>
        <field name="model_id" ref="outdoor_duty.model_travel_authority"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('outdoor_duty.group_travel_authority_audit'))]"/>
    </record>
    <record id="cfo_travel_authority_rule" model="ir.rule">
        <field name="name">CFO</field>
        <field name="model_id" ref="outdoor_duty.model_travel_authority"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('outdoor_duty.group_travel_authority_cfo'))]"/>
    </record>
    <record id="finance_travel_authority_rule" model="ir.rule">
        <field name="name">Finance</field>
        <field name="model_id" ref="outdoor_duty.model_travel_authority"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('outdoor_duty.group_ta_finance'))]"/>
    </record>
    <record id="management_travel_authority_rule" model="ir.rule">
        <field name="name">Management</field>
        <field name="model_id" ref="outdoor_duty.model_travel_authority"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('outdoor_duty.group_od_management'))]"/>
    </record>
    <record id="outdoor_duty_coordinator_record_rule" model="ir.rule">
        <field name="name">Coordinator record rule</field>
        <field name="model_id" ref="outdoor_duty.model_outdoor_duty"/>
        <field name="domain_force">['|',('user_id','=',user.id),('employee_id.department_id.coordinator_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('outdoor_duty.group_od_department_coordinator'))]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="0"/>
    </record>
    <record id="travel_authority_coordinator_record_rule" model="ir.rule">
        <field name="name">TA Coordinator record rule</field>
        <field name="model_id" ref="outdoor_duty.model_travel_authority"/>
        <field name="domain_force">['|', ('user_id','=',user.id), ('employee_id.department_id.coordinator_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('outdoor_duty.group_od_department_coordinator'))]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="0"/>
    </record>


    <record id="administrator_travel_authority_rule" model="ir.rule">
