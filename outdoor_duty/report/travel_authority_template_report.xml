<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_travel_authority">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <div class="article o_report_layout_standard" t-att-data-oe-model="o and o._name"
                     t-att-data-oe-id="o and o.id">
                    <t t-call="outdoor_duty.custom_header_footer_travel_authority"/>
                    <div class="page">
                        <table class="table table-condensed" style="border: 2px solid black;">
                            <tbody>
                                <tr style="text-align: left;">
                                    <th>Name</th>
                                    <td>
                                        <span t-field="o.employee_id"/>
                                    </td>
                                    <th>Department</th>
                                    <td>
                                        <span t-field="o.department_id"/>
                                    </td>
                                    <th>TA No</th>
                                    <td>
                                        <span t-field="o.name_seq"/>
                                    </td>
                                </tr>
                                <tr style="text-align: left;">
                                    <th>Designation</th>
                                    <td>
                                        <span t-field="o.job_id"/>
                                    </td>
                                    <th>Employee No</th>
                                    <td>
<!--                                        <span t-field="o.emp_no"/>-->
                                    </td>
                                    <th>Date</th>
                                    <td>
                                        <span t-field="o.date"/>
                                    </td>
                                </tr>
                                <tr style="text-align: left;">
                                    <th colspan="1">Customer</th>
                                    <td colspan="1">
                                        <span t-field="o.partner_id"/>
                                    </td>
                                    <th colspan="2">Visit Location</th>
                                    <td colspan="2">
                                        <span t-field="o.visit_location"/>
                                    </td>
                                </tr>
                                <tr style="text-align: left;">
                                    <th colspan="2">Purpose Of Visit</th>
                                    <td colspan="4">
                                        <span t-field="o.purpose"/>
                                    </td>
                                </tr>
                                <tr style="text-align: left;">
                                    <th colspan="2">Team Members: </th>
                                    <td colspan="4">
                                        <span t-field="o.team"/>
                                    </td>
                                </tr>
                                <tr style="text-align: left;">
                                    <th colspan="1">Departure</th>
                                    <td colspan="1">
                                        <span t-field="o.departure"/>
                                    </td>
                                    <th colspan="2">Arrival</th>
                                    <td colspan="2">
                                        <span t-field="o.arrival"/>
                                    </td>
                                </tr>
                                <tr style="text-align: left;">
                                    <th colspan="1">Travel Route</th>
                                    <td colspan="1">
                                        <span t-field="o.travel_route"/>
                                    </td>
                                    <th colspan="2">Mode of Travel</th>
                                    <td colspan="2">
                                        <span t-field="o.travel_mode"/>
                                    </td>
                                </tr>


                                <tr style="background-color: black; color: white;">
                                    <th colspan="6">Estimated Expenses</th>
                                </tr>
                                <tr>
                                    <th colspan="2">Type of expense</th>
                                    <th colspan="1">Disc. of expense</th>
                                    <th colspan="1">No of days</th>
                                    <th colspan="1">Rate/day</th>
                                    <th colspan="1">Total Expense</th>
                                </tr>
                                <t t-foreach="o.expense_line_ids" t-as="line">
                                    <tr>
                                        <td colspan="2">
                                            <span t-field="line.expense_id"/>
                                        </td>
                                        <td colspan="1">
                                            <span t-field="line.descript"/>
                                        </td>
                                        <td colspan="1">
                                            <span t-field="line.days"/>
                                        </td>
                                        <td colspan="1">
                                            <span t-field="line.rate"/>
                                        </td>
                                        <td colspan="1">
                                            <span t-field="line.sub_total"/>
                                        </td>
                                    </tr>

                                </t>
                                <tr>
                                    <th colspan="5" style="text-align:left;">
                                        Total:
                                    </th>

                                    <th colspan="1">
                                        <span t-field="o.total"/>
                                    </th>
                                </tr>
                            </tbody>
                        </table>
                        <br/>
                        <br/>
                        <br/>
                        <div class="col-md-12">
                            <div class="row">
                                <span t-field="o.narration" />

                            </div>

                        </div>
                        <br/>
                        <br/>
                        <br/>
                        <br/>
                        <br/>
                        <br/>
                       <div class="col-md-12">
                            <div class="row">
                                <div class="col-2">
                                    <span t-field="o.user_id" />
                                    <br/>
                                    <span style="border-top : 1px solid black;">Prepared By</span>

                                </div>
                                <div class="col-3">
                                    <span t-field="o.sub_hod" />
                                    <br/>
                                    <span style="border-top : 1px solid black;">Approved By Sub HOD</span>

                                </div>
                                <div class="col-3">
                                    <span t-field="o.hod"/>
                                    <br/>
                                    <span style="border-top : 1px solid black;">Approve By HOD</span>

                                </div>
                                <div class="col-2">
                                    <span t-field="o.audit"/>
                                    <br/>
                                    <span style="border-top : 1px solid black;">Audited By</span>

                                </div>
                                <div class="col-2">
                                    <span t-field="o.cfo"/>
                                    <br/>
                                    <span style="border-top : 1px solid black;">Approved By CFO</span>
                                </div>


                            </div>

                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>
