<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record model="ir.module.category" id="module_category_emp_manual_cpl">
        <field name="name">CPL Request</field>
        <field name="description">Category for CPL Requested By Employee</field>
        <field name="sequence">48</field>
    </record>

    <!--    User Groups-->
    <record id="group_epm_cpl_user" model="res.groups">
        <field name="name">User: Own Documents Only</field>
        <field name="category_id" ref="module_category_emp_manual_cpl"/>
        <field name="comment">the user will have access to his own data in the funds module.</field>
    </record>
    <record id="group_emp_cpl_manager" model="res.groups">
        <field name="name">Manager,Assistant Manager</field>
        <field name="category_id" ref="module_category_emp_manual_cpl"/>
    </record>
    <record id="group_emp_cpl_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="category_id" ref="module_category_emp_manual_cpl"/>
    </record>
    <record id="group_emp_cpl_administrator" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="module_category_emp_manual_cpl"/>
    </record>


    <!--    Rule for all groups-->
    <record id="user_cpl_record_rule" model="ir.rule">
        <field name="name">Only Own Records</field>
        <field name="model_id" ref="sl_manual_cpl.model_sl_manual_cpl"/>
        <field name="domain_force">[('user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('sl_manual_cpl.group_epm_cpl_user'))]"/>
    </record>
    <record model="ir.rule" id="manager_cpl_record_rule">
        <field name="name">only own team Records(HOD)</field>
        <field name="model_id" ref="sl_manual_cpl.model_sl_manual_cpl"/>
        <field name="domain_force">['|','|',('user_id','=',user.id),('manager_id.user_id','=',user.id),('coach_id.user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('sl_manual_cpl.group_emp_cpl_manager'))]"/>
    </record>

    <record id="admin_cpl_record_rule" model="ir.rule">
        <field name="name">Admin</field>
        <field name="model_id" ref="sl_manual_cpl.model_sl_manual_cpl"/>
        <field name="domain_force" eval="[(1,'=',1)]"/>
        <field name="groups" eval="[(4, ref('sl_manual_cpl.group_emp_cpl_admin'))]"/>
    </record>
    <record id="administrator_cpl_record_rule" model="ir.rule">
        <field name="name">Administrator</field>
        <field name="model_id" ref="sl_manual_cpl.model_sl_manual_cpl"/>
        <field name="domain_force">['|',(1,'=',1),('company_id','=',False)]</field>
        <field name="groups" eval="[(4, ref('sl_manual_cpl.group_emp_cpl_administrator'))]"/>
    </record>



</odoo>