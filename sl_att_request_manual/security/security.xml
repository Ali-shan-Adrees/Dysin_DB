<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <!-- Module Category -->
    <record model="ir.module.category" id="category_manual_cpl">
        <field name="name">CPL Request</field>
        <field name="description">Category for CPL Requested By Employee</field>
        <field name="sequence">48</field>
    </record>

    <!-- User Groups -->
    <record id="group_manual_cpl_user" model="res.groups">
        <field name="name">User: Own Documents Only</field>
        <field name="category_id" ref="category_manual_cpl"/>
        <field name="comment">The user will have access to their own data in the CPL module.</field>
    </record>

    <record id="group_manual_cpl_manager" model="res.groups">
        <field name="name">Manager / Assistant Manager</field>
        <field name="category_id" ref="category_manual_cpl"/>
    </record>

    <record id="group_manual_cpl_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="category_id" ref="category_manual_cpl"/>
    </record>

    <record id="group_manual_cpl_administrator" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="category_manual_cpl"/>
    </record>

    <!-- Record Rules -->

    <!-- Rule: User sees only own records -->
    <record id="rule_manual_cpl_user" model="ir.rule">
        <field name="name">User: Own Records Only</field>
       <field name="model_id" ref="sl_att_request_manual.model_manual_attendance"/>
        <field name="domain_force">[('user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('sl_att_request_manual.group_manual_cpl_user'))]"/>
    </record>

    <!-- Rule: Manager sees own and team records -->
    <record id="rule_manual_cpl_manager" model="ir.rule">
        <field name="name">Manager: Own and Team Records</field>
        <field name="model_id" ref="sl_att_request_manual.model_manual_attendance"/>
        <field name="domain_force">['|','|',('user_id','=',user.id),('manager_id.user_id','=',user.id),('coach_id.user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('sl_att_request_manual.group_manual_cpl_manager'))]"/>
    </record>

    <!-- Rule: Admin sees everything -->
    <record id="rule_manual_cpl_admin" model="ir.rule">
        <field name="name">Admin: All Records</field>
        <field name="model_id" ref="sl_att_request_manual.model_manual_attendance"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('sl_att_request_manual.group_manual_cpl_admin'))]"/>
    </record>

    <!-- Rule: Super Administrator sees all records including company-less -->
    <record id="rule_manual_cpl_administrator" model="ir.rule">
        <field name="name">Administrator: All Including No Company</field>
        <field name="model_id" ref="sl_att_request_manual.model_manual_attendance"/>
        <field name="domain_force">['|',(1,'=',1),('company_id','=',False)]</field>
        <field name="groups" eval="[(4, ref('sl_att_request_manual.group_manual_cpl_administrator'))]"/>
    </record>

</odoo>