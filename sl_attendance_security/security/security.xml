<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="group_sl_attendance_manager" model="res.groups">
        <field name="name">Attendance: Manager</field>
        <field name="category_id" ref="base.module_category_human_resources_attendances"/>
    </record>

    <record id="group_sl_attendance_regional_admin" model="res.groups">
        <field name="name">Attendance: Regional Admin</field>
        <field name="category_id" ref="base.module_category_human_resources_attendances"/>
    </record>

    <record id="group_sl_attendance_officer" model="res.groups">
        <field name="name">Attendance: Officer (All Access)</field>
        <field name="category_id" ref="base.module_category_human_resources_attendances"/>
    </record>
    <record id="attendance_department_rule" model="ir.rule">
        <field name="name">Attendance: Department Based Access</field>
        <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
        <field name="domain_force">
            [
                '|',
                ('employee_id.user_id', '=', user.id),
                ('employee_id.department_id', 'in', user.allowed_department_ids.ids)
            ]
        </field>
        <field name="groups" eval="[
            (4, ref('sl_attendance_security.group_sl_attendance_manager')),
            (4, ref('sl_attendance_security.group_sl_attendance_regional_admin'))
        ]"/>
    </record>
    <record id="attendance_department_draft_rule" model="ir.rule">
        <field name="name">Draft Attendance: Department Based Access</field>
        <field name="model_id" ref="hr_attendance_zktecho.model_hr_draft_attendance"/>
        <field name="domain_force">
            [
                '|',
                ('employee_id.user_id', '=', user.id),
                ('employee_id.department_id', 'in', user.allowed_department_ids.ids)
            ]
        </field>
        <field name="groups" eval="[
            (4, ref('sl_attendance_security.group_sl_attendance_manager')),
            (4, ref('sl_attendance_security.group_sl_attendance_regional_admin'))
        ]"/>
    </record>
    <record id="attendance_officer_rule" model="ir.rule">
        <field name="name">Attendance: Officer Full Access</field>
        <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[
            (4, ref('sl_attendance_security.group_sl_attendance_officer'))
        ]"/>
    </record>

    <record id="attendance_officer_draft_rule" model="ir.rule">
        <field name="name">Draft Attendance: Officer Full Access</field>
        <field name="model_id" ref="hr_attendance_zktecho.model_hr_draft_attendance"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[
            (4, ref('sl_attendance_security.group_sl_attendance_officer'))
        ]"/>
    </record>

</odoo>
