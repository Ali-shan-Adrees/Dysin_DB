<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <template id="custom_header_footer_for_ta">
        <t t-set="company" t-value="user.company_id"/>
        <div class="header" style="border:1px solid black;">
            <div class="row">
                <div class="col-4" style="text-align:left;padding-left:5px; border-right:1px solid black;">
                    <div t-field="company.partner_id"
                        t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": true}'
                    />
                </div>
                <div class="col-4 text-center" style="border-right:1px solid black;">

                    <div>
                        <h3 style="padding-top:25px;">Visit Report</h3>
                    </div>
                </div>
                <div class="col-4" style="text-align:right;">
                    <img t-if="company.logo" t-att-src="image_data_uri(company.logo)" style="max-height: 80px;" alt="Logo"/>
                </div>

            </div>

        </div>
        <div class="footer">
            <div class="text-center" style="border-top: 1px solid black;">
                <ul class="list-inline mb4 text-nowrap">
                    <li t-if="company.phone" class="list-inline-item d-inline">Phone: <span class="o_force_ltr" t-field="company.phone"/></li>
                    <li t-if
="company.email" class="list-inline-item d-inline">Email: <span t-field="company.email"/></li>
                    <li t-if="company.website" class="list-inline-item d-inline">Web: <span t-field="company.website"/></li>
                    <li t-if="company.vat" class="list-inline-item d-inline"><t t-esc="company.country_id.vat_label or 'Tax ID'"/>: <span t-field="company.vat"/></li>
                </ul>
                <div t-if="report_type == 'pdf'" class="text-muted">
                        Page: <li class="list-inline-item"><strong><span class="page"/> / <span class="topage"/></strong></li>
                    </div>
            </div>
        </div>
    </template>

