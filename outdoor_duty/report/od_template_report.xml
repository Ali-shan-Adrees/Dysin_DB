<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_od">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <div class="article o_report_layout_standard" t-att-data-oe-model="o and o._name"
                     t-att-data-oe-id="o and o.id">
                    <t t-call="outdoor_duty.custom_header_footer"/>
                    <!--                <t t-call="web.external_layout">-->
                    <div class="page">

                        <table class="table table-condensed" style="border: 2px solid black;">
                            <tbody>
                                <tr style="text-align: left;">
                                    <th>Name</th>
                                    <td>
                                        <span t-field="o.employee_id"/>
                                    </td>
                                    <th>Department</th>
                                    <td>
                                        <span t-field="o.department_id"/>
                                    </td>
                                    <th>Od No</th>
                                    <td>
                                        <span t-field="o.name_seq"/>
                                    </td>
                                </tr>
                                <tr style="text-align: left;">
                                    <th colspan="2">Team Members</th>
                                    <td colspan="4">
                                        <span t-field="o.team"/>
                                    </td>


                                </tr>
                                <tr style="text-align: left;">
                                    <th>Designation</th>
                                    <td>
                                        <span t-field="o.job_id"/>
                                    </td>
                                    <th>Employee No</th>
                                    <td>
<!--                                        <span t-field="o.emp_no"/>-->
                                    </td>
                                    <th>Date</th>
                                    <td>
                                        <span t-field="o.date"/>
                                    </td>
                                </tr>
                                <tr style="text-align: left;">
                                    <th colspan="1">Job No</th>
                                    <td colspan="1">
                                        <span t-field="o.job_no"/>
                                    </td>
                                    <th colspan="2">Visit Location</th>
                                    <td colspan="2">
                                        <span t-field="o.work_location"/>
                                    </td>
                                </tr>
                                <tr style="text-align: left;">
                                    <th colspan="2">Purpose Of Visit</th>
                                    <td colspan="4">
                                        <span t-field="o.purpose"/>
                                    </td>
                                </tr>
                                <tr style="text-align: left;">
                                    <th colspan="3">Details</th>
                                    <th colspan="3">Remarks</th>
                                </tr>
                                <tr style="text-align: left;">
                                    <th colspan="3">Warranty Claim</th>
                                    <td colspan="3">
                                        <span t-field="o.claim"/>
                                    </td>
                                </tr>
                                <tr style="text-align: left;">
                                    <th colspan="3">Invoice to Customer</th>
                                    <td colspan="3">
                                        <span t-field="o.invoice_to_customer"/>
                                    </td>
                                </tr>
                                <tr style="text-align: left;">
                                    <th colspan="3">Free of Cost</th>
                                    <td colspan="3">
                                        <span t-field="o.free_of_cost"/>
                                    </td>
                                </tr>
                                <tr style="background-color: black; color: white;">
                                    <th colspan="6">Incase of Vehicle Requirement</th>
                                </tr>
                                <tr style="text-align: left;">
                                    <th colspan="3">Individual accompanying the vehicle</th>
                                    <td colspan="3">
                                        <span t-field="o.vehicle"/>
                                    </td>
                                </tr>
                                <tr style="text-align: left;">
                                    <th>Destination</th>
                                    <td>
                                        <span t-field="o.destination"/>
                                    </td>
                                    <th>Vehicle to be</th>
                                    <td>
                                        <span t-field="o.vehicle_retained"/>
                                    </td>
                                    <th>Not Retained</th>
                                    <td>
                                        <span t-field="o.vehicle_not_retained"/>
                                    </td>
                                </tr>
                                <tr style="text-align: left;">
                                    <th colspan="2">Date Required</th>
                                    <td colspan="1">
                                        <span t-field="o.date_required"/>
                                    </td>
                                    <th colspan="2">Estimated Arrival Date</th>
                                    <td colspan="1">
                                        <span t-field="o.arrival_date"/>
                                    </td>
                                </tr>
                                <tr style="background-color: black; color: white;">
                                    <th colspan="6">To be filled by admin office</th>
                                </tr>
                                <tr style="text-align: left;">
                                    <th colspan="2">Vehicle No</th>
                                    <td colspan="1">
                                        <span t-field="o.vehicle_no"/>
                                    </td>
                                    <th colspan="2">Driver Name</th>
                                    <td colspan="1">
                                        <span t-field="o.driver"/>
                                    </td>
                                </tr>
                                <tr style="text-align: left;">
                                    <th colspan="2">Meter Reading Out</th>
                                    <td colspan="1">
                                        <span t-field="o.m_reading_out"/>
                                    </td>
                                    <th colspan="2">Meter Reading In</th>
                                    <td colspan="1">
                                        <span t-field="o.m_reading_in"/>
                                    </td>
                                </tr>
                                <tr style="text-align: left;">
                                    <th colspan="2">Out Time</th>
                                    <td colspan="1">
                                        <span t-field="o.out_time"/>
                                    </td>
                                    <th colspan="2">In Time</th>
                                    <td colspan="1">
                                        <span t-field="o.in_time"/>
                                    </td>
                                </tr>


                            </tbody>
                        </table>
                        <br/>
                        <br/>

                        <div class="col-md-12">
                            <b>Note: Request must be submitted at least</b>
                            <br/>
                            (a). With in city before (2 Hour)
                            <br/>
                            (b). Out of City before (One Day)
                            <br/>

                        </div>

                        <br/>
                        <br/>
                         <div class="col-md-12">
                            <div class="row">
                                <div class="col-3">
                                    <span t-field="o.user_id" />
                                    <br/>
                                    <span style="border-top : 1px solid black;">Prepared By</span>

                                </div>
                                <div class="col-3">
                                    <span t-field="o.sub_hod" />
                                    <br/>
                                    <span style="border-top : 1px solid black;">Approved By Sub HOD</span>

                                </div>
                                <div class="col-3">
                                    <span t-field="o.hod"/>
                                    <br/>
                                    <span style="border-top : 1px solid black;">Approved By HOD</span>

                                </div>
                                <div class="col-3">
                                    <span t-field="o.admin"/>
                                    <br/>
                                    <span  style="border-top : 1px solid black;">Approved By Admin</span>

                                </div>


                            </div>

                        </div>
                    </div>
                </div>
                <!--                </t>-->

            </t>
        </t>
    </template>
</odoo>
